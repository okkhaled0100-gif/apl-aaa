<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مكافأة القسم</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Tajawal', 'Segoe UI', sans-serif; }
        body {
            background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 100%);
            color: #fff; min-height: 100vh; padding-top: 70px;
        }
        .main-header {
            position: fixed; top: 0; left: 0; right: 0; height: 60px;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            border-bottom: 1px solid rgba(108, 92, 231, 0.3);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 15px; z-index: 999;
        }
        .header-btn {
            background: rgba(255,255,255,0.1); border: none; color: #fff;
            width: 40px; height: 40px; border-radius: 12px; cursor: pointer;
            display: flex; align-items: center; justify-content: center; font-size: 18px;
        }
        .header-title { font-size: 17px; font-weight: bold; }
        .container { max-width: 700px; margin: 0 auto; padding: 20px; }
        .cat-hero {
            text-align: center; margin-bottom: 25px;
        }
        .cat-hero img {
            width: 80px; height: 80px; border-radius: 20px; object-fit: cover;
            margin-bottom: 12px; border: 2px solid rgba(108,92,231,0.4);
        }
        .cat-hero h2 { font-size: 22px; margin-bottom: 6px; }
        .cat-hero .progress-text { color: #a29bfe; font-size: 15px; font-weight: 600; }
        .cards-grid {
            display: grid; grid-template-columns: repeat(5, 1fr);
            gap: 12px; margin-bottom: 25px;
        }
        .stamp-card {
            aspect-ratio: 1; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; font-weight: 700; position: relative;
            background: rgba(255,255,255,0.05);
            border: 2px dashed rgba(255,255,255,0.15); color: rgba(255,255,255,0.3);
        }
        .stamp-card.filled {
            background: linear-gradient(135deg, #6c5ce7, #a29bfe);
            border: 2px solid transparent; color: #fff;
            box-shadow: 0 4px 15px rgba(108,92,231,0.4);
        }
        .gift-card-wrap { margin-top: 10px; }
        .gift-card {
            border-radius: 18px; padding: 24px; text-align: center;
            background: rgba(255,255,255,0.05);
            border: 2px dashed rgba(0,184,148,0.3);
        }
        .gift-card.ready {
            background: linear-gradient(135deg, #00b894, #00cec9);
            border: 2px solid transparent;
        }
        .gift-card .gift-icon { font-size: 48px; margin-bottom: 12px; }
        .gift-card h3 { font-size: 19px; margin-bottom: 8px; }
        .gift-card p { font-size: 14px; opacity: 0.9; margin-bottom: 16px; }
        .claim-btn {
            width: 100%; padding: 15px; border: none; border-radius: 12px;
            background: #fff; color: #00b894; font-weight: 800; font-size: 16px;
            cursor: pointer; font-family: 'Tajawal', sans-serif;
        }
        .claim-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .locked-note { font-size: 13px; opacity: 0.7; margin-top: 8px; }
        .loading { text-align: center; padding: 50px; color: #8a8a9e; }
    </style>
</head>
<body>
    <header class="main-header">
        <button class="header-btn" onclick="window.location.href='/rewards'">
            <i class="fas fa-arrow-right"></i>
        </button>
        <div class="header-title">🎁 مكافأة القسم</div>
        <div style="width:40px;"></div>
    </header>

    <div class="container">
        <div id="content">
            <div class="loading"><i class="fas fa-spinner fa-spin"></i> جارِ التحميل...</div>
        </div>
    </div>

    <script>
        const CATEGORY_ID = "{{ category_id }}";

        async function loadCategory() {
            const content = document.getElementById('content');
            try {
                const res = await fetch('/api/rewards/category/' + CATEGORY_ID);
                const data = await res.json();
                if (data.status === 'success' && data.category) {
                    render(data.category);
                } else {
                    content.innerHTML = '<div class="loading">' + (data.message || 'القسم غير متاح') + '</div>';
                }
            } catch(e) {
                content.innerHTML = '<div class="loading">خطأ في التحميل</div>';
            }
        }

        function render(cat) {
            const content = document.getElementById('content');
            const count = cat.purchase_count || 0;
            const goal = cat.goal || 10;
            const ready = cat.ready;
            const giftsAvailable = cat.gifts_available || 0;
            const img = cat.image_url || 'https://placehold.co/80x80/6c5ce7/ffffff?text=' + encodeURIComponent(cat.name);

            let cards = '';
            for (let i = 1; i <= goal; i++) {
                const filled = i <= count;
                cards += `<div class="stamp-card ${filled ? 'filled' : ''}">${filled ? '✓' : i}</div>`;
            }

            let giftHtml = '';
            if (ready) {
                if (giftsAvailable > 0) {
                    giftHtml = `
                        <div class="gift-card ready">
                            <div class="gift-icon">🎁</div>
                            <h3>مبروك! هديتك جاهزة</h3>
                            <p>أكملت ${goal} مشتريات. استلم هديتك المجانية الآن!</p>
                            <button class="claim-btn" onclick="claimGift()">استخدام الهدية</button>
                        </div>`;
                } else {
                    giftHtml = `
                        <div class="gift-card ready">
                            <div class="gift-icon">🎁</div>
                            <h3>هديتك جاهزة!</h3>
                            <p>لكن لا توجد هدايا متوفرة حالياً. سيتم توفيرها قريباً، وتقدّمك محفوظ.</p>
                            <button class="claim-btn" disabled>بانتظار توفّر الهدايا</button>
                        </div>`;
                }
            } else {
                giftHtml = `
                    <div class="gift-card">
                        <div class="gift-icon">🔒</div>
                        <h3>الهدية مقفلة</h3>
                        <p>أكمل ${goal} مشتريات لفتح هديتك. باقي ${goal - count}!</p>
                    </div>`;
            }

            content.innerHTML = `
                <div class="cat-hero">
                    <img src="${img}" alt="">
                    <h2>${cat.name}</h2>
                    <div class="progress-text">${count} من ${goal} عملية شراء</div>
                </div>
                <div class="cards-grid">${cards}</div>
                <div class="gift-card-wrap">${giftHtml}</div>`;
        }

        async function claimGift() {
            if (!confirm('هل تريد استخدام هديتك الآن؟')) return;
            const btn = document.querySelector('.claim-btn');
            if (btn) { btn.disabled = true; btn.textContent = 'جارِ الاستلام...'; }
            try {
                const res = await fetch('/api/rewards/claim', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ category_id: CATEGORY_ID })
                });
                const data = await res.json();
                if (data.status === 'success') {
                    if (data.delivery_type === 'manual') { showManualForm(data); }
                    else { showGiftResult(data); }
                } else {
                    alert(data.message || 'تعذّر الاستلام');
                    if (btn) { btn.disabled = false; btn.textContent = 'استخدام الهدية'; }
                }
            } catch(e) {
                alert('خطأ في الاتصال');
                if (btn) { btn.disabled = false; btn.textContent = 'استخدام الهدية'; }
            }
        }

        function showManualForm(data) {
            const content = document.getElementById('content');
            const instr = (data.instructions || 'أدخل البيانات المطلوبة').replace(/</g,'&lt;');
            content.innerHTML = `
                <div class="cat-hero"><h2>🎁 هديتك جاهزة!</h2></div>
                <div class="gift-card ready" style="text-align:center;">
                    <div class="gift-icon">🎁</div>
                    <h3>أكمل بيانات الهدية</h3>
                    <p style="margin:12px 0;">المطلوب منك:</p>
                    <div style="background:rgba(0,0,0,0.3);border-radius:12px;padding:14px;margin:10px 0;font-size:15px;line-height:1.8;">${instr}</div>
                    <textarea id="manualInput" rows="4" placeholder="اكتب بياناتك هنا..." style="width:100%;box-sizing:border-box;border-radius:12px;padding:12px;font-size:15px;border:none;margin:10px 0;resize:vertical;"></textarea>
                    <button class="claim-btn" id="submitManualBtn" onclick="submitManual()">إرسال الطلب</button>
                </div>`;
        }
        async function submitManual() {
            const ta = document.getElementById('manualInput');
            const val = (ta ? ta.value : '').trim();
            if (!val) { alert('الرجاء إدخال البيانات المطلوبة'); return; }
            const btn = document.getElementById('submitManualBtn');
            if (btn) { btn.disabled = true; btn.textContent = 'جارِ الإرسال...'; }
            try {
                const res = await fetch('/api/rewards/submit_manual', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ category_id: CATEGORY_ID, user_input: val })
                });
                const data = await res.json();
                if (data.status === 'success') {
                    showGiftResult({ delivery_type: 'manual', message: data.message });
                } else {
                    alert(data.message || 'تعذّر الإرسال');
                    if (btn) { btn.disabled = false; btn.textContent = 'إرسال الطلب'; }
                }
            } catch(e) {
                alert('خطأ في الاتصال');
                if (btn) { btn.disabled = false; btn.textContent = 'إرسال الطلب'; }
            }
        }
        function showGiftResult(data) {
            const content = document.getElementById('content');
            let inner = '';
            if (data.delivery_type === 'instant') {
                inner = `
                    <div class="gift-icon">🎉</div>
                    <h3>${data.message}</h3>
                    <p>هذه هي هديتك المجانية:</p>
                    <div style="background:rgba(0,0,0,0.3);border-radius:12px;padding:16px;margin:16px 0;word-break:break-all;font-size:15px;line-height:1.8;">${(data.code||'').replace(/</g,'&lt;')}</div>
                    <p style="font-size:12px;opacity:0.8;">احفظ الكود في مكان آمن</p>`;
            } else {
                inner = `
                    <div class="gift-icon">🎉</div>
                    <h3>${data.message}</h3>
                    <p>سيتواصل معك فريقنا قريباً لتنفيذ هديتك.</p>`;
            }
            content.innerHTML = `
                <div class="cat-hero"><h2>🎁 مبروك!</h2></div>
                <div class="gift-card ready" style="text-align:center;">${inner}
                    <button class="claim-btn" onclick="window.location.href='/rewards'" style="margin-top:16px;">العودة للمكافآت</button>
                </div>`;
        }

        document.addEventListener('DOMContentLoaded', loadCategory);
    </script>
</body>
</html>
